PORT=4000
ALLOWED_ORIGIN=http://localhost:3000

# Firebase Admin SDK (From Firebase Console -> Project Settings -> Service Accounts -> Generate new private key)
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxx@your-project-id.iam.gserviceaccount.com
# Use \n for newlines in the private key if putting it on one line, or just quote the multi-line string.
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_KEY_HERE\n-----END PRIVATE KEY-----\n"

# Firebase Storage Bucket (for file uploads)
FIREBASE_STORAGE_BUCKET=your-project-id.appspot.com
